# Canonical base URL for metadata, sitemap, Open Graph.
# Set this to your production URL on Railway (e.g. https://nicolasdenigris.dev).
NEXT_PUBLIC_SITE_URL=https://nicolaspilegidenigris.dev

# Resend (transactional email for the contact form). When RESEND_API_KEY or
# RESEND_FROM is unset, the API logs the message and returns ok without
# sending - the home keeps the CopyEmailLink as the working fallback.
RESEND_API_KEY=
RESEND_FROM=portfolio@nicolaspilegidenigris.dev
RESEND_TO=nicolas.denigris91@icloud.com

# Plausible Analytics. When NEXT_PUBLIC_PLAUSIBLE_DOMAIN is unset, the
# analytics script is not injected and track() calls no-op. NEXT_PUBLIC_
# PLAUSIBLE_HOST defaults to https://plausible.io; set it for self-hosted.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_HOST=
